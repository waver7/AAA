# Database (required for Prisma-backed features and demo seed)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autoapply"

# Auth (use a long random value in production)
NEXTAUTH_SECRET="dev-only-secret-change-me"

# AI provider (optional in demo mode)
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Feature flags
ENABLE_AUTOMATION="false"   # Set true only after optional Playwright install
DEMO_MODE="true"            # If true, AI routes return safe mock output when API key is absent

# Optional queue infra
REDIS_URL="redis://localhost:6379"
